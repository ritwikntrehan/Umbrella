{
  "name": "umbrella-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "pilot:grants": "npm run pilot:grants -w @umbrella/jobs",
    "pilot:grants:source-check": "npm run pilot:grants:source-check -w @umbrella/jobs",
    "test:grants-pilot": "npm run test -w @umbrella/jobs",
    "pilot:grants:bulletin": "npm run pilot:grants:bulletin -w @umbrella/jobs",
    "pilot:grants:bulletin:inspect": "npm run pilot:grants:bulletin:inspect -w @umbrella/jobs",
    "pilot:grants:editorial": "npm run pilot:grants:editorial -w @umbrella/jobs",
    "pilot:grants:editorial:inspect": "npm run pilot:grants:editorial:inspect -w @umbrella/jobs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
