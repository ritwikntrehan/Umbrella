{
  "name": "umbrella-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "pilot:grants": "npm run pilot:grants -w @umbrella/jobs",
    "pilot:grants:source-check": "npm run pilot:grants:source-check -w @umbrella/jobs",
    "test:grants-pilot": "npm run test -w @umbrella/jobs",
    "pilot:grants:bulletin": "npm run pilot:grants:bulletin -w @umbrella/jobs",
    "pilot:grants:bulletin:inspect": "npm run pilot:grants:bulletin:inspect -w @umbrella/jobs",
    "pilot:grants:editorial": "npm run pilot:grants:editorial -w @umbrella/jobs",
    "pilot:grants:editorial:inspect": "npm run pilot:grants:editorial:inspect -w @umbrella/jobs",
    "pilot:trade": "npm run pilot:trade -w @umbrella/jobs",
    "pilot:trade:source-check": "npm run pilot:trade:source-check -w @umbrella/jobs",
    "pilot:trade:bulletin": "npm run pilot:trade:bulletin -w @umbrella/jobs",
    "pilot:trade:editorial": "npm run pilot:trade:editorial -w @umbrella/jobs",
    "test:web": "npm run test -w @umbrella/web",
    "pilot:market-signals": "npm run pilot:market-signals -w @umbrella/jobs",
    "pilot:market-signals:source-check": "npm run pilot:market-signals:source-check -w @umbrella/jobs",
    "pilot:market-signals:bulletin": "npm run pilot:market-signals:bulletin -w @umbrella/jobs",
    "pilot:market-signals:editorial": "npm run pilot:market-signals:editorial -w @umbrella/jobs",
    "pilot:manufacturing": "npm run pilot:manufacturing -w @umbrella/jobs",
    "pilot:manufacturing:source-check": "npm run pilot:manufacturing:source-check -w @umbrella/jobs",
    "pilot:manufacturing:bulletin": "npm run pilot:manufacturing:bulletin -w @umbrella/jobs",
    "pilot:manufacturing:editorial": "npm run pilot:manufacturing:editorial -w @umbrella/jobs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
