{
  "name": "umbrella-platform",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "umbrella-platform",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "tsx": "^4.19.2",
        "typescript": "^5.6.3"
      }
    },
    "apps/jobs": {
      "name": "@umbrella/jobs",
      "version": "0.1.0",
      "dependencies": {
        "@umbrella/channel-config": "0.1.0",
        "@umbrella/core": "0.1.0",
        "@umbrella/source-adapters": "0.1.0"
      }
    },
    "apps/web": {
      "name": "@umbrella/web",
      "version": "0.1.0",
      "dependencies": {
        "@umbrella/channel-config": "0.1.0",
        "@umbrella/ui": "0.1.0"
      },
      "devDependencies": {
        "typescript": "^5.6.3"
      }
    },
    "node_modules/@esbuild/linux-x64": {
      "version": "0.27.4",
      "cpu": [
        "x64"
      ],
      "dev": true,
      "license": "MIT",
      "optional": true,
      "os": [
        "linux"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@umbrella/channel-config": {
      "resolved": "packages/channel-config",
      "link": true
    },
    "node_modules/@umbrella/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@umbrella/jobs": {
      "resolved": "apps/jobs",
      "link": true
    },
    "node_modules/@umbrella/source-adapters": {
      "resolved": "packages/source-adapters",
      "link": true
    },
    "node_modules/@umbrella/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "node_modules/@umbrella/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/esbuild": {
      "version": "0.27.4",
      "dev": true,
      "hasInstallScript": true,
      "license": "MIT",
      "bin": {
        "esbuild": "bin/esbuild"
      },
      "engines": {
        "node": ">=18"
      },
      "optionalDependencies": {
        "@esbuild/aix-ppc64": "0.27.4",
        "@esbuild/android-arm": "0.27.4",
        "@esbuild/android-arm64": "0.27.4",
        "@esbuild/android-x64": "0.27.4",
        "@esbuild/darwin-arm64": "0.27.4",
        "@esbuild/darwin-x64": "0.27.4",
        "@esbuild/freebsd-arm64": "0.27.4",
        "@esbuild/freebsd-x64": "0.27.4",
        "@esbuild/linux-arm": "0.27.4",
        "@esbuild/linux-arm64": "0.27.4",
        "@esbuild/linux-ia32": "0.27.4",
        "@esbuild/linux-loong64": "0.27.4",
        "@esbuild/linux-mips64el": "0.27.4",
        "@esbuild/linux-ppc64": "0.27.4",
        "@esbuild/linux-riscv64": "0.27.4",
        "@esbuild/linux-s390x": "0.27.4",
        "@esbuild/linux-x64": "0.27.4",
        "@esbuild/netbsd-arm64": "0.27.4",
        "@esbuild/netbsd-x64": "0.27.4",
        "@esbuild/openbsd-arm64": "0.27.4",
        "@esbuild/openbsd-x64": "0.27.4",
        "@esbuild/openharmony-arm64": "0.27.4",
        "@esbuild/sunos-x64": "0.27.4",
        "@esbuild/win32-arm64": "0.27.4",
        "@esbuild/win32-ia32": "0.27.4",
        "@esbuild/win32-x64": "0.27.4"
      }
    },
    "node_modules/get-tsconfig": {
      "version": "4.13.7",
      "dev": true,
      "license": "MIT",
      "dependencies": {
        "resolve-pkg-maps": "^1.0.0"
      },
      "funding": {
        "url": "https://github.com/privatenumber/get-tsconfig?sponsor=1"
      }
    },
    "node_modules/resolve-pkg-maps": {
      "version": "1.0.0",
      "dev": true,
      "license": "MIT",
      "funding": {
        "url": "https://github.com/privatenumber/resolve-pkg-maps?sponsor=1"
      }
    },
    "node_modules/tsx": {
      "version": "4.21.0",
      "dev": true,
      "license": "MIT",
      "dependencies": {
        "esbuild": "~0.27.0",
        "get-tsconfig": "^4.7.5"
      },
      "bin": {
        "tsx": "dist/cli.mjs"
      },
      "engines": {
        "node": ">=18.0.0"
      },
      "optionalDependencies": {
        "fsevents": "~2.3.3"
      }
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/channel-config": {
      "name": "@umbrella/channel-config",
      "version": "0.1.0",
      "dependencies": {
        "@umbrella/core": "0.1.0"
      }
    },
    "packages/core": {
      "name": "@umbrella/core",
      "version": "0.1.0"
    },
    "packages/source-adapters": {
      "name": "@umbrella/source-adapters",
      "version": "0.1.0",
      "dependencies": {
        "@umbrella/core": "0.1.0"
      }
    },
    "packages/ui": {
      "name": "@umbrella/ui",
      "version": "0.1.0"
    }
  }
}
