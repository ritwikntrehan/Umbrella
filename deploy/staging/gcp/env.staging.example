# Staging environment example for Cloud Run service/job.
# Copy to your deploy pipeline context; do not commit secrets.

# Core GCP settings
GCP_PROJECT=your-gcp-project
GCP_REGION=us-central1

# Artifact Registry contract
# Expected image base:
#   ${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT}/${AR_REPOSITORY}/umbrella-web:${IMAGE_TAG}
#   ${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT}/${AR_REPOSITORY}/umbrella-jobs:${IMAGE_TAG}
AR_REPOSITORY=umbrella-staging
IMAGE_TAG=staging-manual
WEB_IMAGE=us-central1-docker.pkg.dev/your-gcp-project/umbrella-staging/umbrella-web:staging-manual
JOBS_IMAGE=us-central1-docker.pkg.dev/your-gcp-project/umbrella-staging/umbrella-jobs:staging-manual

# Service identities (already created in the prior setup task)
WEB_SA_EMAIL=umbrella-web-staging@your-gcp-project.iam.gserviceaccount.com
JOBS_SA_EMAIL=umbrella-jobs-staging@your-gcp-project.iam.gserviceaccount.com
SCHEDULER_SA_EMAIL=umbrella-scheduler-staging@your-gcp-project.iam.gserviceaccount.com

# Cloud Run resource names
WEB_SERVICE_NAME=umbrella-web-staging
JOBS_NAME=umbrella-jobs-staging
SCHEDULER_NAME=umbrella-jobs-schedule-staging

NODE_ENV=production
WEB_PORT=3000
RUNNER_SCHEDULE=*/30 * * * *

# Artifact storage contract
UMBRELLA_ARTIFACT_STORAGE_MODE=gcs
UMBRELLA_ARTIFACT_LOCAL_DIR=/var/lib/umbrella/artifacts
UMBRELLA_DATA_DIR=/var/lib/umbrella/artifacts
UMBRELLA_GCS_ARTIFACT_BUCKET=umbrella-staging-artifacts
UMBRELLA_GCS_ARTIFACT_PREFIX=artifacts

# Runtime metadata
UMBRELLA_GCP_PROJECT=your-gcp-project
UMBRELLA_GCP_REGION=us-central1

# Optional web metadata (if omitted, smoke script resolves via Cloud Run service)
UMBRELLA_WEB_BASE_URL=https://umbrella-web-staging-<hash>-uc.a.run.app
