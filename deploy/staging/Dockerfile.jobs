FROM node:20-alpine AS base
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
COPY tsconfig.base.json ./
COPY types ./types

RUN npm ci

ENV NODE_ENV=production
ENV UMBRELLA_DATA_DIR=/var/lib/umbrella/artifacts

CMD ["npm", "run", "pilot:grants:editorial"]
